---
const { name, bio, avatar, align, deco } = Astro.props;

const avatarPath = avatar ? `img/${avatar}` : 'img/default.webp';
const fallbackPath = 'img/default.webp';

let imgClasses = 'rounded-full min-w-18 w-18 h-18 relative';
let headerClasses = 'mb-7 flex gap-4';
let lineClasses = 'w-12 h-0.5 rounded-full bg-accent my-2';

if( deco === 'all' || deco === 'avatar' ) {
  imgClasses = imgClasses + ' ring-3 ring-accent';
}

if(align === 'center') {
  headerClasses = headerClasses + ' flex-col-reverse items-center';
  lineClasses = lineClasses + ' mx-auto';
} else {
  headerClasses = headerClasses + ' flex-row-reverse';

}
---

<header class={headerClasses}>
  <div class="flex-grow">
    <h1 class="font-semibold text-lg">{ name }</h1>
    { (deco === 'all' || deco === 'lines') && 
      <div aria-hidden="true" class={lineClasses}></div> 
    }
    {bio && <p class="mt-0.5 text-muted">{bio}</p>}
  </div>
  <div class={imgClasses}>
    <img
      src={avatarPath}
      class="rounded-full"
      alt={name || "Avatar"}
      width="72"
      height="72"
      loading="eager"
      fetchpriority="high"
      onerror={`this.onerror=null; this.src='${fallbackPath}'`}
    />

    { (deco === 'all' || deco === 'avatar') && 
      <div aria-hidden="true" class="w-4 h-4 border-2 border-bg rounded-full absolute bottom-0 right-0 bg-accent"></div> 
    }
  </div>
</header>

<script>
  import { initDynamicImages } from '../assets/js/resolve-path.js';
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDynamicImages);
  } else {
    initDynamicImages();
  }
</script>